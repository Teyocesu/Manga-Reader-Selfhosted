# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# Local data paths
# Use absolute paths on a server if you want data outside the repository.
DATA_DIR=./data
STORAGE_DIR=./storage

# Storage limits
# STORAGE_QUOTA_BYTES takes priority when set.
STORAGE_QUOTA_GB=25
STORAGE_QUOTA_BYTES=

# Upload safety limits
MAX_UPLOAD_MB=1024
MAX_IMAGES_PER_CHAPTER=1000

# Authentication
# Set this before exposing the app to your LAN, Tailscale, or the internet.
APP_PASSWORD=change-me
